{
  "name": "meu-regional-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/migrate.ts run",
    "migrate:rollback": "bun run src/migrate.ts rollback",
    "migrate:list": "bun run src/migrate.ts list",
    "test": "bun test src/test"
