    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.58.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
