# JWT para autenticação
# Gerar com: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui

# Banco de dados
DATABASE_PATH=/app/data/meu-regional.db

# Ambiente (development, production)
NODE_ENV=development

# Pular inicialização do banco (útil para produção)
# SKIP_DB_INIT=true

# API URL para o frontend
VITE_API_URL=http://localhost:3000

# Portas
PORT=3000

# ===========================================
# Registro de novos usuários
# ===========================================
# Desabilitar registro (true/false)
# Quando true, retorna erro 403 na rota de registro
DISABLE_REGISTRATION=false

# ===========================================
# Scraper API (container separado)
# ===========================================
# URL do serviço de scraping
SCRAPER_API_URL=http://scraper:4000
