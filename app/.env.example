# URL base da API
# Em produção (Docker): usar '/api' (proxy reverso do Caddy)
# Em desenvolvimento local: usar 'http://localhost:3000/api'
VITE_API_BASE_URL=/api

# ===========================================
# Registro de novos usuários
# ===========================================
# Desabilitar registro (true/false)
# Quando true, esconde link de registro e redireciona /register para /login
VITE_DISABLE_REGISTRATION=false
