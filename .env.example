# JWT para autenticação
# Gerar uma chave segura com: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui

# Banco de dados
DATABASE_PATH=/app/data/meu-regional.db

# Ambiente (development, production)
NODE_ENV=production

# ===========================================
# Scraper API (container separado)
# ===========================================
# URL do serviço de scraping
SCRAPER_API_URL=http://scraper:4000

# Credenciais Spotify (opcional, necessário para scraping)
SPOTIFY_EMAIL=seu-email@exemplo.com
SPOTIFY_PASSWORD=sua-senha-aqui

# Configurações do Scraper
SCRAPER_HEADLESS=true
